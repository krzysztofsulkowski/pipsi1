@using TimeCapsule.Models.Dto
@model CreateCapsuleDto

<div class="modal fade" id="createCapsuleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Save" asp-controller="CapsuleManagement"
                  method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Nowa kapsuła</h5>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Type" class="form-label"></label>
                        <select asp-for="Type" class="form-select">
                            <option value="">— wybierz —</option>
                            @foreach (var t in Enum.GetValues(typeof(TimeCapsule.Models.DatabaseModels.CapsuleType)))
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="OpeningDate" class="form-label"></label>
                        <input asp-for="OpeningDate" type="datetime-local"
                               class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Introduction" class="form-label"></label>
                        <textarea asp-for="Introduction" class="form-control"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="MessageContent" class="form-label"></label>
                        <textarea asp-for="MessageContent" class="form-control"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Recipients" class="form-label"></label>
                        <input asp-for="Recipients" class="form-control"
                               placeholder="email1,email2,..." />
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="NotifyRecipients"
                               class="form-check-input" />
                        <label asp-for="NotifyRecipients"
                               class="form-check-label"></label>
                    </div>
                    @* Dodaj pola Links i UploadedImages wg potrzeb *@
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Anuluj
                    </button>
                    <button type="submit" class="btn btn-primary">
                        Zapisz
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
