@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Potwierdzenie zmiany hasła";
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
}

<div class="login-modal">
    <!-- 5) Duży “×” -->
    <button type="button" class="close-btn" onclick="window.location='/'">&times;</button>

    <!-- 6) Tytuł -->
    <h1 class="login-title">@ViewData["Title"]</h1>

    <!-- Tekst potwierdzenia -->
    <p class="confirmation-text">
        Na podany wcześniej adres e-mail wysłaliśmy wiadomość z linkiem do zresetowania hasła.<br />
        Sprawdź swoją skrzynkę (oraz folder spam), aby dokończyć proces zmiany hasła.
    </p>
</div>
