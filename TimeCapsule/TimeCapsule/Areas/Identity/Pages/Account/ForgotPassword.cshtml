@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Zmiana hasła";
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
}

<div class="login-modal">
    <button type="button" class="close-btn" onclick="window.location='/'">&times;</button>

    <h1 class="login-title">@ViewData["Title"]</h1>

    <form id="forgot-password" method="post" class="login-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email"
                   class="form-control"
                   autocomplete="username"
                   placeholder="e-mail*" />
            <label asp-for="Input.Email">e-mail*</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <p class="confirmation-text">
            Na podany adres e-mail wyślemy wiadomość zawierającą link do zresetowania hasła.
            Sprawdź swoją skrzynkę odbiorczą (oraz folder spam), aby odzyskać dostęp do konta.
        </p>

        <button type="submit" class="btn-login">
            Wyślij wiadomość e-mail
        </button>
    </form>
</div>

<span class="required-note">* pole wymagane</span>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
