@page
@model LoginModel
@{
    ViewData["Title"] = "Logowanie";
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
}

<div class="login-modal">
    <button type="button" class="close-btn" onclick="window.location='/'">&times;</button>

    <h1 class="login-title">@ViewData["Title"]</h1>

    <form id="account" method="post" class="login-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="e-mail*" />
            <label asp-for="Input.Email">e-mail*</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="hasło*" />
            <label asp-for="Input.Password">hasło*</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <a asp-page="./ForgotPassword" class="forgot-link">Nie pamiętam hasła</a>

        <button type="submit" class="btn-login">Zaloguj się</button>

        <div class="text-center mt-4">
            <a asp-page="./ExternalLogin"
               asp-route-provider="Google"
               asp-route-returnUrl="~/"
               class="btn-login btn-google d-inline-flex align-items-center justify-content-center">

               
                <svg xmlns="http://www.w3.org/2000/svg"
                     width="20" height="20"
                     fill="currentColor"
                     class="bi bi-google google-svg-icon"
                     viewBox="0 0 16 16">
                    <path d="M15.545 6.558a9.4 9.4 0 0 1 .139 1.626c0 2.434-.87
                        4.492-2.384 5.885h.002C11.978 15.292 10.158 16 8 16A8
                        8 0 1 1 8 0a7.7 7.7 0 0 1 5.352 2.082l-2.284 2.284A4.35
                        4.35 0 0 0 8 3.166c-2.087 0-3.86 1.408-4.492
                        3.304a4.8 4.8 0 0 0 0 3.063h.003c.635 1.893
                        2.405 3.301 4.492 3.301 1.078 0 2.004-.276
                        2.722-.764h-.003a3.7 3.7 0 0 0
                         1.599-2.431H8v-3.08z" />
                </svg>

                
                <span class="google-btn-text">Zaloguj się przez Google</span>
            </a>
        </div>
    </form>
</div>

<span class="required-note">* pole wymagane</span>

<div class="post-modal-footer">
    Nie posiadasz konta?
    <a asp-page="./Register" class="btn-register">Zarejestruj się</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


